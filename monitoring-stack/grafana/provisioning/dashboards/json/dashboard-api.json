{
  "title": "Gateway de Pagamentos - API Python",
  "uid": "quarkus-api-detail",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    { "type": "row", "title": "HTTP", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 100 },

    {
      "id": 1, "type": "timeseries", "title": "Throughput (req/s)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(rate(payment_requests_total[1m]))", "legendFormat": "req/s" }]
    },
    {
      "id": 2, "type": "timeseries", "title": "Taxa de Erro 5xx (%)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [
        { "color": "green", "value": null }, { "color": "red", "value": 5 }
      ] } }, "overrides": [] },
      "targets": [{
        "expr": "(sum(rate(payment_requests_total{status=~\"5..\"}[1m])) / sum(rate(payment_requests_total[1m]))) * 100",
        "legendFormat": "erro 5xx"
      }]
    },
    {
      "id": 3, "type": "timeseries", "title": "Contagem por Status",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum by(status) (rate(payment_requests_total[1m]))", "legendFormat": "{{status}}" }]
    },
    {
      "id": 4, "type": "timeseries", "title": "Latência Média",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [{
        "expr": "rate(payment_latency_seconds_sum[1m]) / rate(payment_latency_seconds_count[1m])",
        "legendFormat": "latência média"
      }]
    },
    {
      "id": 5, "type": "timeseries", "title": "Latência (p50, p95, p99)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(payment_latency_seconds_bucket[1m])) by (le))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(payment_latency_seconds_bucket[1m])) by (le))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(payment_latency_seconds_bucket[1m])) by (le))", "legendFormat": "p99" }
      ]
    },

    { "type": "row", "title": "Segurança (Eventos Anômalos)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 }, "id": 102 },
    {
      "id": 30, "type": "timeseries", "title": "Scanning — Requisições Inválidas/s",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 10 }
      ] } }, "overrides": [] },
      "targets": [{ "expr": "rate(payment_invalid_requests_total[1m])", "legendFormat": "inválidas/s" }]
    },
    {
      "id": 31, "type": "timeseries", "title": "Taxa de Erros 4xx (%)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [
        { "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 15 }
      ] } }, "overrides": [] },
      "targets": [{
        "expr": "(sum(rate(payment_requests_total{status=~\"4..\"}[1m])) / sum(rate(payment_requests_total[1m]))) * 100",
        "legendFormat": "erro 4xx"
      }]
    },
    {
      "id": 32, "type": "logs", "title": "Logs de Segurança (4xx/5xx)",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "showTime": true, "wrapLogMessage": true },
      "targets": [{ "expr": "{job=\"docker-logs\"} |= \"HTTP_404\" or {job=\"docker-logs\"} |= \"HTTP_500\" or {job=\"docker-logs\"} |= \"invalid_route\"" }]
    }
  ]
}
